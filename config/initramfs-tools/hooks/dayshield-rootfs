#!/bin/sh
# Build-time initramfs hook: bundle the tools needed for DayShield rootfs
# image updates into the initramfs.  Runs during update-initramfs -c.

PREREQ=""
prereqs() { echo "$PREREQ"; }
case $1 in prereqs) prereqs; exit 0 ;; esac

. /usr/share/initramfs-tools/hook-functions

# squashfs module — needed to loop-mount squashfs images at boot
manual_add_modules squashfs

# rsync — extracts the staged squashfs image to the root partition with
# --delete semantics so files removed in the new rootfs disappear from
# the existing rootfs as well (no stale packages or kernel modules)
copy_exec /usr/bin/rsync /usr/bin

# unsquashfs — fallback extractor if rsync mode fails for any reason
copy_exec /usr/sbin/unsquashfs /sbin

# sha256sum — verify the staged squashfs against its sidecar before applying
copy_exec /usr/bin/sha256sum /usr/bin

# blkid — finds the DAYSHIELD_BOOT partition by label at boot time
copy_exec /sbin/blkid /sbin
